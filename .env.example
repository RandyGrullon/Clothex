EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# URL del servidor de IA local (ai-server). En el navegador usa localhost;
# en el teléfono pon la IP LAN de tu PC, ej: http://192.168.1.50:8000
EXPO_PUBLIC_AI_URL=http://localhost:8000
# Token GRATIS de Pollinations (enter.pollinations.ai) — habilita el generador
# de fotos try-on y el análisis con visión en la PWA.
EXPO_PUBLIC_POLLINATIONS_TOKEN=
